# AcornArranger Next.js — environment template.
# Copy to `.env.local` for development or `.env.production` on the VPS.
# Never commit real values; both target files are gitignored.

# Supabase project — find in Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=

# VRPTW scheduler sidecar. Leave as-is when running the Python service on
# the same host via systemd or `make dev` at the repo root.
ACORN_SCHEDULER_URL=http://127.0.0.1:8001
ACORN_SCHEDULER_TIMEOUT_MS=60000

# Public origin of the deployed app, used for Next.js `metadataBase` so
# absolute URLs in OG tags resolve correctly. Leave unset for local dev.
SITE_URL=
